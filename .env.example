# Copier ce fichier en .env (ne jamais committer .env)

# RPC Sepolia : Infura, Alchemy, ou autre fournisseur (URL HTTPS)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/VOTRE_CLE

# Copier la même SEPOLIA_RPC_URL dans web/.env.local pour le front (route /api/rpc-sepolia).

# Clé privée du compte qui DÉPLOIE (sans 0x ou avec 0x selon l’outil — Hardhat accepte souvent les deux)
# ATTENTION : ne jamais partager cette clé ni la mettre sur GitHub
PRIVATE_KEY=

# Adresse du proxy UUPS (pour scripts/upgrade.ts après déploiement V1)
# PROXY_ADDRESS=0x...

# Optionnel : vérification sur Etherscan après déploiement
# ETHERSCAN_API_KEY=
